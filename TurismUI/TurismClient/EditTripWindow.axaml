<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TurismClient.EditTripWindow"
        Title="Excursie"
        Width="460" Height="390"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <Window.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="Margin"     Value="0,0,0,4"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="FontSize"   Value="12"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Height"     Value="34"/>
            <Setter Property="Margin"     Value="0,0,0,12"/>
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background"   Value="#1E6FD9"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding"      Value="16,8"/>
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1759B3"/>
        </Style>
    </Window.Styles>

    <StackPanel Margin="24" Spacing="0">
        <TextBlock Classes="label" Text="Destinație (Tourist Attraction) *"/>
        <TextBox x:Name="AttractionBox"/>

        <TextBlock Classes="label" Text="Companie transport (Transport Company) *"/>
        <TextBox x:Name="CompanyBox"/>

        <TextBlock Classes="label" Text="Plecare (YYYY-MM-DD HH:mm) *"/>
        <TextBox x:Name="DepartureBox"/>

        <Grid ColumnDefinitions="*,16,*" Margin="0,0,0,12">
            <StackPanel Grid.Column="0">
                <TextBlock Classes="label" Text="Preț (RON) *"/>
                <NumericUpDown x:Name="PriceBox"
                               Minimum="0.01" Increment="1"
                               FormatString="0.00" Value="0"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Classes="label" Text="Locuri disponibile *"/>
                <NumericUpDown x:Name="SeatsBox"
                               Minimum="1" Increment="1" Value="1"/>
            </StackPanel>
        </Grid>

        <TextBlock x:Name="ErrorText"
                   Foreground="#C0392B" FontSize="12"
                   IsVisible="False" Margin="0,0,0,8"/>

        <Grid ColumnDefinitions="*,Auto,8,Auto" Margin="0,4,0,0">
            <Button Grid.Column="1" Classes="primary"
                    Content="Salvează" Click="SaveButton_OnClick"/>
            <Button Grid.Column="3" Padding="16,8"
                    Content="Anulează" Click="CancelButton_OnClick"/>
        </Grid>
    </StackPanel>

</Window>

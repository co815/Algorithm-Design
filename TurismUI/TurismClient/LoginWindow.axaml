<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TurismClient.LoginWindow"
        Title="Autentificare - Turism" Width="400" Height="250"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20" Spacing="15" VerticalAlignment="Center">
        <TextBlock Text="Autentificare Agenție" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
        <TextBox x:Name="UsernameBox" Watermark="Nume utilizator" />
        <TextBox x:Name="PasswordBox" Watermark="Parolă" PasswordChar="*" />
        <Button Content="Autentificare" Width="150" HorizontalAlignment="Center" Click="LoginButton_OnClick"/>
        <TextBlock x:Name="ErrorText" Foreground="Red" HorizontalAlignment="Center" TextWrapping="Wrap"/>
    </StackPanel>
</Window>

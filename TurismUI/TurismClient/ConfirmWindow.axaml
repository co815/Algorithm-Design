<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TurismClient.ConfirmWindow"
        Title="Confirmare"
        Width="420" Height="150"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="24" Spacing="20">
        <TextBlock x:Name="MessageText" TextWrapping="Wrap" FontSize="13"/>
        <Grid ColumnDefinitions="*,Auto,8,Auto">
            <Button Grid.Column="1"
                    Background="#C0392B" Foreground="White"
                    FontWeight="SemiBold" CornerRadius="6" Padding="16,8"
                    Content="Da, șterge"
                    Click="YesButton_OnClick"/>
            <Button Grid.Column="3" Padding="16,8"
                    Content="Anulează"
                    Click="NoButton_OnClick"/>
        </Grid>
    </StackPanel>

</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:TurismClient.Models" 
        x:Class="TurismClient.MainWindow"
        Title="Aplicație Turism" Width="900" Height="620">
    
    <StackPanel Margin="20" Spacing="15">
        
        <TextBlock Text="Excursii Disponibile" FontSize="24" FontWeight="Bold"/>
        
        <ListBox x:Name="TripsListBox" Height="360" SelectionMode="Single">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:Trip">
                    <StackPanel Orientation="Horizontal" Spacing="20">
                        <TextBlock Text="{Binding TouristAttraction}" FontWeight="Bold" Width="120"/>
                        <TextBlock Text="{Binding TransportCompany}" Width="120"/>
                        <TextBlock Text="{Binding DepartureTime}" Width="150"/>
                        <TextBlock Text="{Binding Price, StringFormat='{}{0} RON'}" Width="80"/>
                        <TextBlock Text="{Binding AvailableSeats, StringFormat='{}Locuri: {0}'}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock Text="Rezervare" FontSize="18" FontWeight="Bold"/>
        <Grid ColumnDefinitions="2*,2*,1*,Auto" ColumnSpacing="10">
            <TextBox x:Name="CustomerNameBox" Watermark="Nume client" Grid.Column="0"/>
            <TextBox x:Name="CustomerPhoneBox" Watermark="Telefon client" Grid.Column="1"/>
            <TextBox x:Name="TicketsCountBox" Watermark="Nr. bilete" Grid.Column="2"/>
            <Button Grid.Column="3" Content="Rezervă" Width="120" Click="BookTripButton_OnClick"/>
        </Grid>
        <TextBlock x:Name="StatusText" />
        
    </StackPanel>
</Window>
